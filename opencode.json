{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "rust": {
      "command": ["rust-analyzer"]
    }
  },
  "permission": {
    "external_directory": {
      "~/.cargo/registry/src/**": "allow",
      "/tmp/**": "allow"
    }
  },
  "agent": {
    "plan": {
      "temperature": 0.1
    },
    "build": {
      "temperature": 0.1
    }
  }
}
