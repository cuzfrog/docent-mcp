{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "rust": {
      "command": ["rust-analyzer"]
    }
  },
  "permission": {
    "external_directory": {
      "~/.cargo/registry/src/**": "allow",
      "/tmp/**": "allow"
    }
  },
  "agent": {
    "plan": {
      "temperature": 0.1
    },
    "build": {
      "temperature": 0.1
    }
  },
  "mcp": {
    "windows-shutdown": {
      "type": "remote",
      "url": "http://192.168.1.6:18000/sse",
      "enabled": true
    }
  }
}
